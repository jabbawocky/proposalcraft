{
  "name": "proposalcraft",
  "version": "1.4.59",
  "description": "MCP server that drafts winning proposals in your voice from a client brief",
  "type": "module",
  "bin": {
    "proposalcraft": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "sample-proposals"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "mcpName": "io.github.jabbawocky/proposalcraft",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "claude-desktop",
    "proposal",
    "proposal-generator",
    "proposal-writing",
    "client-proposal",
    "business-proposal",
    "freelance",
    "freelancer-tools",
    "consulting",
    "sales",
    "business-development",
    "productivity",
    "ai",
    "ai-writing",
    "anthropic",
    "automation"
  ],
  "author": "Mat Carter",
  "license": "MIT",
  "homepage": "https://jabbawocky.github.io/proposalcraft/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jabbawocky/proposalcraft.git"
  },
  "bugs": {
    "url": "https://github.com/jabbawocky/proposalcraft/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
