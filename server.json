{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.jabbawocky/proposalcraft",
  "description": "Draft client proposals in your voice from past winning work. No API key, no cloud.",
  "repository": {
    "url": "https://github.com/jabbawocky/proposalcraft",
    "source": "github"
  },
  "version": "1.4.67",
  "packages": [
    {
      "registryType": "npm",
      "name": "proposalcraft",
      "identifier": "proposalcraft",
      "version": "1.4.67",
      "transport": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "github:jabbawocky/proposalcraft"]
      },
      "environmentVariables": []
    }
  ]
}
